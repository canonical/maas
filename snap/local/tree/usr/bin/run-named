#!/bin/bash -e
#  Copyright 2017 Canonical Ltd.  This software is licensed under the
#  GNU Affero General Public License version 3 (see the file LICENSE).

mkdir -p "$SNAP_DATA/bind"

# Copy bind9 config files and patch paths for the snap environment.
sed "s|/etc/bind/|$SNAP_DATA/bind/|g" \
    "$SNAP/etc/bind/named.conf" > "$SNAP_DATA/bind/named.conf"

# Write named.conf.options with snap-specific paths.
# This replaces the bind9-shipped file which only sets the cache directory.
cat > "$SNAP_DATA/bind/named.conf.options" <<EOF
options {
    directory "$SNAP_DATA/bind/cache";
    pid-file "$SNAP_DATA/bind/named.pid";
    bindkeys-file "$SNAP/etc/bind/bind.keys";
    session-keyfile "$SNAP_DATA/bind/session.key";
    auth-nxdomain no;
    listen-on-v6 { any; };
    include "$SNAP_DATA/bind/named.conf.options.inside.maas";
};
EOF

sed "s|/usr/share/dns/|$SNAP/usr/share/dns/|g" \
    "$SNAP/etc/bind/named.conf.root-hints" > "$SNAP_DATA/bind/named.conf.root-hints"

# Copy named.conf.local and append the MAAS zone config include.
# This mirrors what edit_named_options does.
cp "$SNAP/etc/bind/named.conf.local" "$SNAP_DATA/bind/named.conf.local"
echo "include \"$SNAP_DATA/bind/named.conf.maas\";" >> "$SNAP_DATA/bind/named.conf.local"

mkdir -p "$SNAP_DATA/bind/cache"

# generate MAAS bind configuration
MAAS_ZONE_FILE_CONFIG_DIR="$SNAP_DATA/bind" \
  MAAS_DNS_CONFIG_DIR="$SNAP_DATA/bind" \
  "$SNAP/usr/bin/maas-rack" setup-dns --no-clobber

exec "$SNAP/usr/sbin/named" \
  -c "$SNAP_DATA/bind/named.conf" \
  -g
