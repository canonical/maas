#. Description
#: ../maas-region-controller.templates:3001
#: ../maas-region-controller.templates:4001
msgid ""
"The Ubuntu MAAS server requires the administrator to create a username and "
"password combination."
msgstr ""

#. Type: string
#. Description
#: ../maas-region-controller.templates:3001
msgid "Please provide the username for the MAAS account."
msgstr ""

#. Type: password
#. Description
