[Unit]
Description=MAAS Agent daemon
Documentation=https://maas.io/docs
Wants=network-online.target
After=maas-rackd.service
BindsTo=maas-rackd.service
ConditionPathExists=/etc/maas/agent.yaml

[Service]
User=maas
Group=maas
# Use FIPS wrapper to conditionally activate Go FIPS mode
ExecStart=/usr/share/maas/maas-agent-fips-wrapper.sh start --supervised

[Install]
WantedBy=multi-user.target
